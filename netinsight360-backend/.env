# ============================================
# NETINSIGHT 360 - CONFIGURATION
# ============================================

# Application
APP_NAME="NetInsight 360"
APP_ENV=development
APP_URL=http://localhost:8080/netinsight360
APP_TIMEZONE=Africa/Abidjan

# Base de données locale
DB_HOST=localhost
DB_PORT=3306
DB_NAME=netinsight360
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Base de données distante pour les données RAN KPIs (NetPulseAI_NetworkInsight)
REMOTE_DB_HOST=10.171.16.120
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=NetPulseAI_NetworkInsight
REMOTE_DB_USER=fo_npm
REMOTE_DB_PASS=fo_npm
REMOTE_DB_CHARSET=utf8mb4

# Connexion alternative via SSH tunnel (optionnel)
# SSH_TUNNEL_ENABLED=false
# SSH_TUNNEL_HOST=gateway.example.com
# SSH_TUNNEL_USER=tunnel_user
# SSH_TUNNEL_PORT=22

# Session
SESSION_NAME=netinsight_session
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# Logging
LOG_LEVEL=debug
LOG_PATH=logs/