# Fichier volontairement assaini.
# Les secrets réels vivent désormais dans .env.local (gitignoré).

APP_NAME="NetInsight 360"
APP_ENV=development
APP_URL=http://localhost:8080/netinsight360
APP_TIMEZONE=Africa/Abidjan
APP_KEY=change-me-in-env-local
TOTP_ENCRYPTION_KEY=change-me-in-env-local

DB_HOST=localhost
DB_PORT=3306
DB_NAME=netinsight360
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

REMOTE_DB_HOST=change-me-in-env-local
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=NetPulseAI_NetworkInsight
REMOTE_DB_USER=change-me-in-env-local
REMOTE_DB_PASS=change-me-in-env-local
REMOTE_DB_CHARSET=utf8mb4

SESSION_NAME=netinsight_session
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=Strict

LOG_LEVEL=debug
LOG_PATH=logs/