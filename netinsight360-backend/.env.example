APP_NAME="NetInsight 360"
APP_ENV=development
APP_URL=http://localhost:8080/netinsight360
APP_TIMEZONE=Africa/Abidjan
APP_KEY=base64:replace-with-generated-app-key
TOTP_ENCRYPTION_KEY=base64:replace-with-generated-totp-key

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=netinsight360
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

REMOTE_DB_HOST=remote-host.example.net
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=NetPulseAI_NetworkInsight
REMOTE_DB_USER=remote-user
REMOTE_DB_PASS=replace-me
REMOTE_DB_CHARSET=utf8mb4

SESSION_NAME=netinsight_session
SESSION_LIFETIME=7200
SESSION_SECURE=auto
SESSION_HTTP_ONLY=true
SESSION_SAMESITE=Strict
