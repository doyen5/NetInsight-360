# NetInsight 360 — Sécurité Apache

# Bloquer l'accès aux fichiers sensibles
<FilesMatch "(\.env|\.env\..*|\.git|composer\.lock|composer\.json|package\.json|package-lock\.json)$">
    Require all denied
</FilesMatch>

# Bloquer l'accès aux dossiers sensibles
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Corriger la faute de frappe courante sur le dossier netinsight360
    RewriteCond %{REQUEST_URI} ^/netinsigh360(/.*)?$ [NC]
    RewriteRule ^netinsigh360(/.*)?$ /netinsight360$1 [R=301,L]

    RewriteRule ^netinsight360-backend/config/ - [F,L]
    RewriteRule ^netinsight360-backend/logs/ - [F,L]
    # Bloquer data/ SAUF le sous-dossier exports/ (fichiers téléchargeables générés)
    RewriteRule ^netinsight360-backend/data/(?!exports/) - [F,L]
</IfModule>

# Désactiver le listing des répertoires
Options -Indexes

# En-têtes de sécurité
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>
